# =============================================================================
# Camping — environment variables
# Copy to .env for local dev. Configure these in Vercel for prod/preview.
# =============================================================================

# --- Database (Supabase) -----------------------------------------------------
# Pooled connection (port 6543, pgbouncer) — runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<host>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma migrations
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<host>.pooler.supabase.com:5432/postgres"

# --- Auth.js v5 --------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# Base URL of the app. Auto-detected on Vercel; required locally.
AUTH_URL="http://localhost:3000"
# Resend API key used by the Auth.js Email provider for magic links
AUTH_RESEND_KEY=""
# From-address for magic-link emails (use onboarding@resend.dev until you verify a domain)
AUTH_EMAIL_FROM="onboarding@resend.dev"

# --- Resend (transactional email outside auth) -------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- Stripe (TEST MODE for dev — switch to live keys in prod env vars) -------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_CONNECT_CLIENT_ID=""
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook` for local dev,
# or from the Stripe dashboard webhook endpoint for prod.
STRIPE_WEBHOOK_SECRET=""

# --- Supabase Storage --------------------------------------------------------
# Project URL (same project as DATABASE_URL). Public.
NEXT_PUBLIC_SUPABASE_URL=""
# Anon key — safe to expose; used for public reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SERVER ONLY. Never import into client code.
# Used by src/lib/storage.ts for uploads/deletes and by
# scripts/setup-supabase-storage.ts to create the property-maps bucket.
SUPABASE_SERVICE_ROLE_KEY=""

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron --------------------------------------------------------------------
# Shared secret Vercel Cron sends in `Authorization: Bearer ${CRON_SECRET}`.
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Vercel project env vars (Production scope).
CRON_SECRET=""

# --- Platform admin (Phase 7a) -----------------------------------------------
# Comma-separated emails authorized to sign in to /platform-admin. The first
# sign-in by one of these emails creates the PlatformAdmin row; subsequent
# admins can be added via the back-office UI. Leave blank to disable
# bootstrap (then no one can sign in until you seed a PlatformAdmin row by
# hand). Set the same value in Vercel.
PLATFORM_ADMIN_BOOTSTRAP_EMAILS=""
